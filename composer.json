{
    "name": "draft-status/draft-status",
    "description": "Mark draft posts by completion status with priority levels",
    "type": "wordpress-plugin",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.1",
        "yoast/phpunit-polyfills": "^1.1"
    },
    "autoload-dev": {
        "psr-4": {
            "DraftStatus\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
